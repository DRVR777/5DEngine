          "get.kbU": "$thing:legacy/hero-knockback/legacy-mount/_kbU",
          "set.kbU": "$thing:legacy/hero-knockback/legacy-mount/_kbU",
          "get.kbV": "$thing:legacy/hero-knockback/legacy-mount/_kbV",
          "set.kbV": "$thing:legacy/hero-knockback/legacy-mount/_kbV",
          "actions.getPos": "$kindPos:hero",
          "actions.setPos": "$writePos:hero",
          "actions.resolveMove": "$noop"

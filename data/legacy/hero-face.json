{
  "id": "legacy/hero-face",
  "kind": "legacy-system",
  "name": "legacy_hero_face",
  "facets": [
    {
      "name": "legacy-mount",
      "data": {
        "module_url": "./src/systems/hero_face_tick.js",
        "export": "mountHeroFaceTick",
        "tick_args": [
          "@dt",
          {
            "aiming": "$pointerHeld",
            "inputF": "$const:0",
            "inputR": "$const:0",
            "forward": "$const:{\"x\":0,\"z\":1}",
            "right": "$const:{\"x\":1,\"z\":0}",
            "camYaw": "$inputYaw"
          }
        ],
        "_rotY": 0,
        "bindings": {
          "get.rotY": "$thing:legacy/hero-face/legacy-mount/_rotY",
          "set.rotY": "$thing:legacy/hero-face/legacy-mount/_rotY"
        }
      }
    }
  ],
  "migration": {
    "legacy_mount": "mountHeroFaceTick",
    "status": "NATIVE_VERIFIED",
    "semantic_test": "With yaw=PI/2 and aiming held, native hero-face turns rotY/heading from 0 to PI/2 in one 0.1s tick, matching legacy dt*25 clamp; with KeyD movement and no aim, it turns toward right-vector heading with dt*10 clamp (test_legacy_bridge.mjs iter-793 phase).",
    "native_target": "hero-face"
  }
}

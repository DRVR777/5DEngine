{
  "id": "legacy/scope-fov",
  "kind": "legacy-system",
  "name": "legacy_scope_fov",
  "facets": [
    {
      "name": "legacy-mount",
      "data": {
        "module_url": "./src/systems/scope_fov_tick.js",
        "export":     "mountScopeFovTick",
        "tick_args": [
          "@dt",
          {
            "aiming":           "$pointerHeld",
            "computerOpen":     "$const:false",
            "computerEntering": "$const:false",
            "isSprinting":      "$input:ShiftLeft",
            "heroDead":         "$const:false",
            "buildMode":        "$const:false",
            "inCar":            "$const:false",
            "currentWeaponId":  "$const:\"pistol\""
          }
        ],
        "_aimAmt":              0,
        "_sprintFovAmt":        0,
        "_wasSniperScope":      false,
        "_sniperSavedCamDist":  6,
        "_camDist":             6,
        "bindings": {
          "get.aimAmt":              "$thing:legacy/scope-fov/legacy-mount/_aimAmt",
          "set.aimAmt":              "$thing:legacy/scope-fov/legacy-mount/_aimAmt",
          "get.sprintFovAmt":        "$thing:legacy/scope-fov/legacy-mount/_sprintFovAmt",
          "set.sprintFovAmt":        "$thing:legacy/scope-fov/legacy-mount/_sprintFovAmt",
          "get.wasSniperScope":      "$thing:legacy/scope-fov/legacy-mount/_wasSniperScope",
          "set.wasSniperScope":      "$thing:legacy/scope-fov/legacy-mount/_wasSniperScope",
          "get.sniperSavedCamDist":  "$thing:legacy/scope-fov/legacy-mount/_sniperSavedCamDist",
          "set.sniperSavedCamDist":  "$thing:legacy/scope-fov/legacy-mount/_sniperSavedCamDist",
          "get.camDist":             "$thing:legacy/scope-fov/legacy-mount/_camDist",
          "set.camDist":             "$thing:legacy/scope-fov/legacy-mount/_camDist",
          "actions.setFov":                "$noop",
          "actions.updateProjectionMatrix": "$noop"
        }
      }
    }
  ]
}

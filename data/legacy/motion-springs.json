{
  "id": "legacy/motion-springs",
  "kind": "legacy-system",
  "name": "legacy_motion_springs",
  "facets": [
    {
      "name": "legacy-mount",
      "data": {
        "module_url": "./src/systems/motion_springs.js",
        "export":     "mountMotionSprings",
        "tick_args": [
          "@dt",
          {
            "moveSpreadTarget": "$const:0",
            "isMoving":         "$inputAny:KeyW,KeyA,KeyS,KeyD",
            "inCar":            "$const:false",
            "buildMode":        "$const:false",
            "heroDead":         "$const:false",
            "canSprint":        "$input:ShiftLeft",
            "inputR":           "$const:0",
            "aiming":           "$pointerHeld"
          }
        ],
        "_moveSpread":    0,
        "_gunBobPhase":   0,
        "_strafeRollAmt": 0,
        "bindings": {
          "get.moveSpread":    "$thing:legacy/motion-springs/legacy-mount/_moveSpread",
          "set.moveSpread":    "$thing:legacy/motion-springs/legacy-mount/_moveSpread",
          "get.gunBobPhase":   "$thing:legacy/motion-springs/legacy-mount/_gunBobPhase",
          "set.gunBobPhase":   "$thing:legacy/motion-springs/legacy-mount/_gunBobPhase",
          "get.strafeRollAmt": "$thing:legacy/motion-springs/legacy-mount/_strafeRollAmt",
          "set.strafeRollAmt": "$thing:legacy/motion-springs/legacy-mount/_strafeRollAmt"
        }
      }
    }
  ]
}

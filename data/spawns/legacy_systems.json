{
  "id": "spawns/legacy_systems",
  "kind": "spawn-set",
  "name": "Legacy mount* subsystems hosted via legacy-mount facet",
  "facets": [
    { "name": "for-kind", "data": "legacy-system" },
    { "name": "comment",  "data": "Each child = one legacy mount* call from game.html, hosted unchanged inside the substrate. The legacy-mount facet's binding DSL ($kind/$tuning/$const/$noop/$log/$global) wires the module's get.X / set.X / actions.X to substrate Things. As each subsystem gets a native Ankhor facet, the corresponding child here is deleted (authority-flip). Order matches GAME_HTML_INVENTORY priority — simple-no-deps first, then HUD, then combat, then AI, etc." }
  ],
  "children": [
    { "id": "legacy/hero-regen", "kind": "legacy-system", "name": "legacy_hero_regen",
      "facets": [
        { "name": "legacy-mount", "data": {
          "module_url": "./src/systems/hero_regen_tick.js",
          "export":     "mountHeroRegenTick",
          "tick_args":  ["@dt", { "nowSec": "@nowSec" }],
          "bindings": {
            "get.heroHp":          "$kind:hero[0]/health/hp",
            "get.maxHp":           "$kind:hero[0]/health/maxHp",
            "get.perkMaxHpBonus":  "$const:0",
            "get.lastDamageT":     "$const:0",
            "get.regenDelay":      "$tuning:hero-tuning/tuning/regen_delay_seconds",
            "get.regenRate":       "$tuning:hero-tuning/tuning/regen_rate_per_second",
            "get.perkRegenBonus":  "$const:0",
            "set.heroHp":          "$kind:hero[0]/health/hp",
            "set.nearDeathFired":  "$noop"
          }
        } }
      ] },

    { "id": "legacy/heartbeat", "kind": "legacy-system", "name": "legacy_heartbeat",
      "facets": [
        { "name": "legacy-mount", "data": {
          "module_url": "./src/systems/heartbeat.js",
          "export":     "mountHeartbeat",
          "tick_args":  ["@dt"],
          "bindings": {
            "get.heroHp":      "$kind:hero[0]/health/hp",
            "get.HERO_MAX_HP": "$kind:hero[0]/health/maxHp",
            "get.heroDead":    "$const:false",
            "get.heartbeatT":  "$thing:legacy/heartbeat/legacy-mount/_heartbeatT",
            "set.heartbeatT":  "$thing:legacy/heartbeat/legacy-mount/_heartbeatT",
            "actions.playSfx": "$log:[heartbeat sfx]"
          }
        } }
      ] },

    { "id": "legacy/fps-tick", "kind": "legacy-system", "name": "legacy_fps_tick",
      "facets": [
        { "name": "legacy-mount", "data": {
          "module_url": "./src/systems/fps_tick.js",
          "export":     "mountFpsTick",
          "tick_args":  ["@perfMs", null],
          "bindings": {
            "get.fpsFrames":  "$thing:legacy/fps-tick/legacy-mount/_frames",
            "get.fpsWindowT": "$thing:legacy/fps-tick/legacy-mount/_windowT",
            "get.fpsDisplay": "$thing:legacy/fps-tick/legacy-mount/_display",
            "set.fpsFrames":  "$thing:legacy/fps-tick/legacy-mount/_frames",
            "set.fpsWindowT": "$thing:legacy/fps-tick/legacy-mount/_windowT",
            "set.fpsDisplay": "$thing:legacy/fps-tick/legacy-mount/_display",
            "actions.onNewFps": "$noop"
          }
        } }
      ] },

    { "id": "legacy/cam-shake", "kind": "legacy-system", "name": "legacy_cam_shake",
      "facets": [
        { "name": "legacy-mount", "data": {
          "module_url": "./src/systems/cam_shake_tick.js",
          "export":     "mountCamShakeTick",
          "tick_args":  ["@dt"],
          "bindings": {
            "get.camShakeAmt":      "$thing:legacy/cam-shake/legacy-mount/_camShakeAmt",
            "set.camShakeAmt":      "$thing:legacy/cam-shake/legacy-mount/_camShakeAmt",
            "actions.offsetCamera": "$noop"
          }
        } }
      ] },

    { "id": "legacy/cam-pitch-springs", "kind": "legacy-system", "name": "legacy_cam_pitch_springs",
      "facets": [
        { "name": "legacy-mount", "data": {
          "module_url": "./src/systems/cam_pitch_springs.js",
          "export":     "mountCamPitchSprings",
          "params": { "camPitchMax": 0.4 },
          "tick_args":  ["@dt"],
          "bindings": {
            "get.recoilPitch":   "$thing:legacy/cam-pitch-springs/legacy-mount/_recoilPitch",
            "get.hitPunchPitch": "$thing:legacy/cam-pitch-springs/legacy-mount/_hitPunchPitch",
            "get.camPitch":      "$thing:legacy/cam-pitch-springs/legacy-mount/_camPitch",
            "set.recoilPitch":   "$thing:legacy/cam-pitch-springs/legacy-mount/_recoilPitch",
            "set.hitPunchPitch": "$thing:legacy/cam-pitch-springs/legacy-mount/_hitPunchPitch",
            "set.camPitch":      "$thing:legacy/cam-pitch-springs/legacy-mount/_camPitch"
          }
        } }
      ] },

    { "id": "legacy/vignette", "kind": "legacy-system", "name": "legacy_vignette",
      "facets": [
        { "name": "legacy-mount", "data": {
          "module_url": "./src/systems/vignette_tick.js",
          "export":     "mountVignetteTick",
          "tick_args":  ["@dt", "@perfMs", "$kind:hero[0]/health/hp", "$kind:hero[0]/health/maxHp", null],
          "bindings": {
            "get.vignetteAmt": "$thing:legacy/vignette/legacy-mount/_vignetteAmt",
            "set.vignetteAmt": "$thing:legacy/vignette/legacy-mount/_vignetteAmt"
          }
        } }
      ] },

    { "id": "legacy/stamina", "kind": "legacy-system", "name": "legacy_stamina",
      "facets": [
        { "name": "legacy-mount", "data": {
          "module_url": "./src/systems/stamina_tick.js",
          "export":     "mountStaminaTick",
          "params": {
            "STAMINA_DRAIN":   25,
            "STAMINA_REGEN":   18,
            "STAMINA_MAX":     100,
            "STAMINA_LOCKOUT": 20
          },
          "tick_args": ["@dt", { "wantsSprint": "$const:false", "isSprinting": "$const:false", "inputMoving": "$const:false" }],
          "bindings": {
            "get.heroEmpT":            "$thing:legacy/stamina/legacy-mount/_heroEmpT",
            "set.heroEmpT":            "$thing:legacy/stamina/legacy-mount/_heroEmpT",
            "get.stamina":             "$thing:legacy/stamina/legacy-mount/_stamina",
            "set.stamina":             "$thing:legacy/stamina/legacy-mount/_stamina",
            "get.heroExtraStaminaMax": "$const:0"
          }
        } }
      ] },

    { "id": "legacy/footstep-sound", "kind": "legacy-system", "name": "legacy_footstep_sound",
      "facets": [
        { "name": "legacy-mount", "data": {
          "module_url": "./src/systems/footstep_sound.js",
          "export":     "mountFootstepSound",
          "tick_args":  ["@dt", { "isMoving": "$const:false", "heroDead": "$const:false", "pointerLocked": "$const:false", "canSprint": "$const:false", "crouching": "$const:false", "onGround": "$const:true" }],
          "bindings": {
            "get.footstepT":  "$thing:legacy/footstep-sound/legacy-mount/_footstepT",
            "set.footstepT":  "$thing:legacy/footstep-sound/legacy-mount/_footstepT",
            "actions.playSfx": "$log:[footstep sfx]"
          }
        } }
      ] }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "kind"],
  "properties": {
    "id": { "type": "string" },
    "kind": { "type": "string" },
    "labels": { "type": "array", "items": { "type": "string" } },
    "coordinates": { "type": "object" },
    "state": { "type": "object" },
    "properties": { "type": "object" },
    "evidence": { "type": "array" },
    "policies": { "type": "array", "items": { "type": "string" } },
    "links": { "type": "array" }
  }
}
